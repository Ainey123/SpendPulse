{
  "version": 2,
  "build": {
    "env": { "PYTHON_VERSION": "3.12" }
  },
  "outputDirectory": "public",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "runtime": "python3.12", "maxLambdaSize": "15mb" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.py" }
  ]
}
